{
  "schema_version": 1,
  "provider_type": "markdown-vault",
  "catalog": {
    "display_name": "Markdown Vault",
    "description": "Configured Markdown vault provider for direct read-only knowledge-base search and cited document retrieval.",
    "badge": "KB",
    "icon": "MD",
    "icon_path": "assets/icon.svg",
    "accent": "#2563eb"
  },
  "config_schema": {
    "default_auth_type": "app_credentials",
    "auth_modes": {
      "app_credentials": {
        "required_fields": []
      }
    },
    "fields": [
      {
        "name": "auth_type",
        "type": "hidden",
        "scope": "instance",
        "default": "app_credentials"
      },
      {
        "name": "vault_path",
        "type": "text",
        "required": true,
        "scope": "instance",
        "label": "Vault Path",
        "placeholder": "/Users/shared/knowledge-vault"
      },
      {
        "name": "include_globs",
        "type": "text",
        "required": false,
        "scope": "instance",
        "default": "**/*.md",
        "label": "Include Globs",
        "placeholder": "**/*.md,docs/**/*.md"
      },
      {
        "name": "exclude_globs",
        "type": "text",
        "required": false,
        "scope": "instance",
        "default": ".obsidian/**,.git/**,**/.*/**,**/node_modules/**",
        "label": "Exclude Globs",
        "placeholder": ".obsidian/**,.git/**,private/**"
      },
      {
        "name": "max_file_bytes",
        "type": "number",
        "required": false,
        "scope": "instance",
        "default": 1048576,
        "label": "Max File Bytes",
        "placeholder": "1048576"
      },
      {
        "name": "max_chunk_chars",
        "type": "number",
        "required": false,
        "scope": "instance",
        "default": 1800,
        "label": "Max Chunk Characters",
        "placeholder": "1800"
      },
      {
        "name": "max_context_chars",
        "type": "number",
        "required": false,
        "scope": "instance",
        "default": 24576,
        "label": "Max Search Context Characters",
        "placeholder": "24576"
      },
      {
        "name": "max_result_chars",
        "type": "number",
        "required": false,
        "scope": "instance",
        "default": 3072,
        "label": "Max Result Characters",
        "placeholder": "3072"
      }
    ]
  },
  "redaction": {
    "sensitive_fields": []
  }
}
